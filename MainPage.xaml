<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CurrencyApp.MainPage"
             Title="FreelanceFX">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="FreelanceFX" FontSize="28" FontAttributes="Bold"
                   TextColor="#1E3C72" HorizontalOptions="Center"/>
            <Label Text="Currency Converter" FontSize="14"
                   TextColor="Gray" HorizontalOptions="Center"/>

            <Frame BorderColor="#CCCCCC" CornerRadius="8" Padding="16">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Amount" FontAttributes="Bold"/>
                    <Entry x:Name="txtAmount" Placeholder="Enter amount"
                           Keyboard="Numeric" Text="1.00"/>

                    <Label Text="From Currency" FontAttributes="Bold"/>
                    <Picker x:Name="cmbFrom" Title="Select currency"/>

                    <Button Text="⇅ Swap" Clicked="BtnSwap_Click"
                            BackgroundColor="#E0E7FF" TextColor="#1E3C72"/>

                    <Label Text="To Currency" FontAttributes="Bold"/>
                    <Picker x:Name="cmbTo" Title="Select currency"/>

                    <Button Text="Convert" Clicked="BtnConvert_Click"
                            BackgroundColor="#1E3C72" TextColor="White"
                            FontAttributes="Bold" FontSize="16"/>

                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="resultFrame" BorderColor="#CCCCCC"
                   CornerRadius="8" Padding="16" IsVisible="False">
                <VerticalStackLayout>
                    <Label x:Name="lblResult" FontSize="18"
                           FontAttributes="Bold" TextColor="#145A32"
                           HorizontalOptions="Center"/>
                    <Label x:Name="lblRate" FontSize="12"
                           TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label x:Name="lblStatus" FontSize="12" TextColor="Gray"
                   HorizontalOptions="Center"/>

            <Label Text="Conversion History" FontAttributes="Bold"
                   FontSize="14" Margin="0,10,0,0"/>
            <CollectionView x:Name="lstHistory" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding .}" FontSize="11"
                               FontFamily="Courier New" Padding="4"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
